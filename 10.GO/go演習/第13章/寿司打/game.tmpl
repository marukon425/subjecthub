// ===== 状態 =====
let budget=3000, maxTime=60, score=0, timeLeft=60;
let gameActive=false;
let plates=[], pid=0;
let combo=0, maxCombo=0, eatCount=0;
let typedCount=0, activePid=null;
let timerIv=null, spawnIv=null;
let spawnDelay=3000, plateDur=10;
let queue=[], totalTimeSec=60;

const belt    = document.getElementById('belt');
const wordJp  = document.getElementById('wordJp');
const wordRomaji = document.getElementById('wordRomaji');
const hint    = document.getElementById('hint');
const hudScore = document.getElementById('hudScore');
const hudTimer = document.getElementById('hudTimer');
const timerBar = document.getElementById('timerBar');
const comboWrap = document.getElementById('comboWrap');
const comboN  = document.getElementById('comboN');

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function nextWord(){if(!queue.length)queue=shuffle([...WORDS]);return queue.pop();}

// ===== 皿スポーン =====
function spawnPlate(){
  if(!gameActive)return;
  const w=nextWord();
  const id=pid++;
  const g=w.p>=500?4:w.p>=400?3:w.p>=300?2:1;
  const el=document.createElement('div');
  el.className='plate';
  el.dataset.id=id; el.dataset.g=g;
  el.style.setProperty('--spd', plateDur+'s');
  const gkClass = w.gk ? ' gunkan' : '';
  el.innerHTML=`
    <div class="bubble">${w.d}</div>
    <div class="dish">
      <div class="sg${gkClass}">
        <div class="st" style="background:${w.c};"></div>
        <div class="sr"></div>
      </div>
    </div>
    <div class="price-tag">¥${w.p}</div>`;
  belt.appendChild(el);

  const pd={id,word:w,el,eaten:false,missed:false};
  plates.push(pd);

  // アニメ終了 = ミス
  el.addEventListener('animationend',()=>{
    if(!pd.eaten) missPlate(pd);
  });

  if(activePid===null) setActive(id);
}

function setActive(id){
  activePid=id; typedCount=0;
  const pd=plates.find(p=>p.id===id);
  if(!pd){activePid=null;updateTyping();return;}
  pd.el.classList.add('active');
  updateTyping();
}

function eatPlate(pd){
  if(pd.eaten||pd.missed)return;
  pd.eaten=true;
  score+=pd.word.p; eatCount++;
  combo++; if(combo>maxCombo)maxCombo=combo;
  updateHUD(); updateCombo();
  showPop('+¥'+pd.word.p, pd.el, false);
  pd.el.classList.add('eating');
  pd.el.classList.remove('active');
  setTimeout(()=>pd.el.remove(),480);
  wordJp.classList.add('ok');
  setTimeout(()=>wordJp.classList.remove('ok'),300);
  activePid=null; typedCount=0;
  setTimeout(()=>{
    const nxt=plates.find(p=>!p.eaten&&!p.missed);
    if(nxt)setActive(nxt.id); else updateTyping();
  },80);
}

function missPlate(pd){
  if(pd.eaten||pd.missed)return;
  pd.missed=true;
  combo=0; updateCombo();
  showPop('MISS', pd.el, true);
  pd.el.classList.add('missing');
  setTimeout(()=>pd.el.remove(),600);
  if(activePid===pd.id){
    activePid=null; typedCount=0;
    const nxt=plates.find(p=>!p.eaten&&!p.missed);
    if(nxt)setActive(nxt.id); else updateTyping();
  }
}

// ===== 表示更新 =====
function updateTyping(){
  const pd=plates.find(p=>p.id===activePid);
  if(!pd){
    wordJp.textContent=''; wordRomaji.innerHTML='';
    hint.textContent='次のお皿をお待ちください...';
    return;
  }
  hint.textContent='';
  wordJp.textContent=pd.word.t;
  const r=pd.word.r;
  const tp=r.slice(0,typedCount);
  const nx=typedCount<r.length?r[typedCount]:'';
  const rm=typedCount<r.length?r.slice(typedCount+1):'';
  wordRomaji.innerHTML=
    `<span class="rt">${tp}</span><span class="rn">${nx}</span><span class="rr">${rm}</span>`;
}

function updateHUD(){
  hudScore.textContent='¥'+score.toLocaleString();
  hudScore.className='hud-val'+(score>=budget?' green':'');
  hudTimer.textContent=timeLeft;
  hudTimer.className='hud-val'+(timeLeft<=10?' red':'');
  const pct=Math.max(0,(timeLeft/totalTimeSec)*100);
  timerBar.style.width=pct+'%';
  if(timeLeft<=10) timerBar.style.background='linear-gradient(90deg,#ff4422,#ff8844)';
  else timerBar.style.background='linear-gradient(90deg,#ff6644,#f0d870)';
}

function updateCombo(){
  if(combo>=3){
    comboWrap.style.display='block';
    comboN.textContent=combo;
    comboN.style.animation='none';
    requestAnimationFrame(()=>{requestAnimationFrame(()=>{comboN.style.animation='comboPop 0.25s ease-out';});});
  } else { comboWrap.style.display='none'; }
}

function showPop(txt, refEl, isMiss){
  const p=document.createElement('div');
  p.className='spop '+(isMiss?'miss':'gain');
  p.textContent=txt;
  const r=refEl.getBoundingClientRect();
  p.style.left=(r.left+r.width/2-30)+'px';
  p.style.top=(r.top-10)+'px';
  document.body.appendChild(p);
  setTimeout(()=>p.remove(),1050);
}

// ===== キー入力 =====
document.addEventListener('keydown',(e)=>{
  if(!gameActive)return;
  if(e.key.length!==1||e.metaKey||e.ctrlKey||e.altKey)return;
  e.preventDefault();
  const pd=plates.find(p=>p.id===activePid);
  if(!pd)return;
  const r=pd.word.r;
  if(e.key===r[typedCount]){
    typedCount++;
    updateTyping();
    if(typedCount>=r.length) eatPlate(pd);
  } else {
    wordJp.classList.add('err');
    setTimeout(()=>wordJp.classList.remove('err'),180);
    combo=0; updateCombo();
  }
});

// ===== ゲームフロー =====
async function startGame(b,t){
  budget=b; totalTimeSec=t; timeLeft=t; score=0;
  gameActive=false;
  // 難易度設定
  if(b>=10000){plateDur=6;spawnDelay=2200;}
  else if(b>=5000){plateDur=8;spawnDelay=2700;}
  else{plateDur=10;spawnDelay=3200;}

  plates.forEach(p=>p.el.remove());
  plates=[]; activePid=null; typedCount=0; combo=0; maxCombo=0; eatCount=0; queue=[];
  document.getElementById('ovStart').style.display='none';
  document.getElementById('ovResult').style.display='none';
  document.getElementById('hudBudget').textContent='¥'+b.toLocaleString();
  hudScore.textContent='¥0'; hudScore.className='hud-val';
  hudTimer.textContent=t; hudTimer.className='hud-val';
  timerBar.style.width='100%'; timerBar.style.background='linear-gradient(90deg,#ff6644,#f0d870)';
  comboWrap.style.display='none';
  wordJp.textContent=''; wordRomaji.innerHTML='';
  hint.textContent='';

  await doCountdown();
  gameActive=true;

  timerIv=setInterval(()=>{
    timeLeft--;
    updateHUD();
    if(timeLeft<=0) endGame();
  },1000);

  spawnPlate();
  spawnIv=setInterval(spawnPlate, spawnDelay);
}

function doCountdown(){
  return new Promise(res=>{
    const ov=document.getElementById('ovCd');
    const nm=document.getElementById('cdNum');
    ov.style.display='flex';
    let n=3;
    const tick=()=>{
      nm.textContent=n;
      nm.style.animation='none';
      requestAnimationFrame(()=>requestAnimationFrame(()=>{nm.style.animation='cdPop 0.9s ease-out forwards';}));
      n--;
      if(n>0){setTimeout(tick,1000);}
      else{
        setTimeout(()=>{
          nm.textContent='スタート！';
          nm.style.animation='none';
          requestAnimationFrame(()=>requestAnimationFrame(()=>{nm.style.animation='cdPop 0.9s ease-out forwards';}));
          setTimeout(()=>{ov.style.display='none';res();},900);
        },1000);
      }
    };
    tick();
  });
}

function endGame(){
  gameActive=false;
  clearInterval(timerIv); clearInterval(spawnIv);
  plates.forEach(p=>p.el.remove());
  plates=[]; activePid=null;
  wordJp.textContent=''; wordRomaji.innerHTML=''; hint.textContent='';

  const diff=score-budget;
  document.getElementById('rBudget').textContent='¥'+budget.toLocaleString();
  document.getElementById('rScore').textContent='¥'+score.toLocaleString();
  document.getElementById('rPlates').textContent=eatCount+'皿';
  document.getElementById('rCombo').textContent=maxCombo+'コンボ';
  const profEl=document.getElementById('rProfit');
  if(diff>=0){
    profEl.textContent='+¥'+diff.toLocaleString()+'　お得！';
    profEl.className='rprofit plus';
  } else {
    profEl.textContent='¥'+diff.toLocaleString()+'　赤字...';
    profEl.className='rprofit minus';
  }
  // 星評価
  const pct=score/budget;
  const stars=pct>=1.5?'★★★':pct>=1.0?'★★☆':pct>=0.5?'★☆☆':'☆☆☆';
  document.getElementById('rStars').textContent=stars;

  setTimeout(()=>{document.getElementById('ovResult').style.display='flex';},1200);
}

function showStart(){
  document.getElementById('ovResult').style.display='none';
  document.getElementById('ovStart').style.display='flex';
}
</script>
